# =============================================================================
# PMO AUTOMATION SYSTEM - ENVIRONMENT CONFIGURATION
# =============================================================================
# This file contains sensitive credentials. NEVER commit to version control.
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual credentials below
# 3. Never commit .env to Git (already in .gitignore)
#
# OBTAINING CREDENTIALS:
# - GOOGLE_API_KEY: https://aistudio.google.com/app/apikeys
# - EMAIL credentials: Gmail App Password (not regular password)
# - SLACK_WEBHOOK_URL: Slack App → Incoming Webhooks
# =============================================================================

# =============================================================================
# GOOGLE GEMINI AI INTEGRATION
# =============================================================================
# Get API key: https://aistudio.google.com/app/apikeys
# Free tier: 60 requests per minute, no credit card required
GOOGLE_API_KEY=your_gemini_api_key_here

# =============================================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# =============================================================================
# Security: Use "App Password" not your regular Gmail password
# Setup: https://myaccount.google.com/apppasswords
# 1. Enable 2-Factor Authentication
# 2. Create App Password for "Mail" service
# 3. Use the 16-character password below
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_16_character_app_password

# =============================================================================
# SLACK INTEGRATION
# =============================================================================
# Create Incoming Webhook: https://api.slack.com/apps
# 1. Create New App
# 2. Enable "Incoming Webhooks"
# 3. Add New Webhook to your workspace
# 4. Copy the full URL below
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# =============================================================================
# OPTIONAL: PROJECT CONFIGURATION OVERRIDES
# =============================================================================
# Leave commented unless you need to override defaults in Scripts/Utils/config.py

# Project settings
# PROJECT_NAME=PMO_Automation_System
# PROJECT_VERSION=1.5

# File paths (relative to project root)
# DATA_DIR=Data
# OUTPUT_DIR=Data/Output
# LOGS_DIR=Logs
# ARCHIVE_DIR=04_Archive

# Report settings
# REPORT_FORMAT=xlsx
# REPORT_TIMEZONE=Europe/Lisbon
